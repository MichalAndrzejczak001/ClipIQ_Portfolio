<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ClipIQ API Suite" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.clipiq.api.AnalysisControllerTestNGTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.clipiq.api.AnalysisControllerTestNGTest"/>
            <class name="com.clipiq.api.AnalysisApiRestAssuredTest"/>
        </classes>
    </test>

    <test name="Negative Tests">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <classes>
            <class name="com.clipiq.api.AnalysisApiRestAssuredTest"/>
        </classes>
    </test>

</suite>
